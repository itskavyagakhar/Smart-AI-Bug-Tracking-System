PORT=5000

# Access token secret (short-lived, 15 min) and refresh token secret (long-lived,
# 7 days, stored as an httpOnly cookie). Use two DIFFERENT random strings.
JWT_SECRET=change_this_to_any_random_long_string
JWT_REFRESH_SECRET=change_this_to_a_different_random_long_string

# Get this from MongoDB Atlas: Connect -> Drivers -> copy the connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bugtracker?retryWrites=true&w=majority

# Optional — get from https://aistudio.google.com. Without it, AI features
# return a clearly-labeled fallback instead of a real Gemini response.
GEMINI_API_KEY=

# Optional — email notifications via SMTP (e.g. Gmail, SendGrid, Mailtrap).
# Leave all blank to disable email notifications entirely (in-app + real-time
# notifications still work either way). For Gmail: use an "App Password", not
# your normal password — https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
